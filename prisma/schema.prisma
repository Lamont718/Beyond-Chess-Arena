// BeyondChess Arena — data model.
//
// LOCAL DEV: provider = "sqlite" (zero setup; DATABASE_URL="file:./dev.db").
// PRODUCTION: change provider to "postgresql" and point DATABASE_URL at Neon.
// The schema is written to be portable across both (no arrays/enums — lists are
// stored as JSON strings, statuses as plain strings).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String
  role         String   @default("KID") // "COACH" | "KID"
  rating       Int      @default(1000)
  xp           Int      @default(0) // experience points → level (see lib/levels.ts)
  wins         Int      @default(0)
  losses       Int      @default(0)
  draws        Int      @default(0)
  emoji        String   @default("♟️") // simple kid-friendly avatar
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  // Daily-puzzle streak tracking.
  puzzleStreak     Int     @default(0) // current consecutive-day streak
  puzzleBestStreak Int     @default(0) // longest streak ever
  puzzleLastDate   String? // last solved day key, "YYYY-MM-DD" (America/New_York)
  puzzlesSolved    Int     @default(0) // lifetime puzzles solved

  gamesAsWhite       Game[]      @relation("WhiteGames")
  gamesAsBlack       Game[]      @relation("BlackGames")
  challengesSent     Challenge[] @relation("ChallengeFrom")
  challengesReceived Challenge[] @relation("ChallengeTo")
  chatMessages       ChatMessage[]
  puzzleSolves       PuzzleSolve[]
  tournamentPlayers  TournamentPlayer[]
}

model Tournament {
  id             String    @id @default(cuid())
  name           String
  status         String    @default("upcoming") // "upcoming" | "active" | "completed"
  timeControlSec Int       @default(300)
  incrementSec   Int       @default(0)
  createdById    String
  createdAt      DateTime  @default(now())
  startedAt      DateTime?
  endedAt        DateTime?

  players TournamentPlayer[]

  @@index([status])
}

model TournamentPlayer {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String
  points       Float    @default(0) // win = 1, draw = 0.5
  wins         Int      @default(0)
  draws        Int      @default(0)
  losses       Int      @default(0)
  joinedAt     DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@unique([tournamentId, userId])
  @@index([tournamentId])
}

model PuzzleSolve {
  id        String   @id @default(cuid())
  userId    String
  dateKey   String   // "YYYY-MM-DD" (America/New_York) — one puzzle per day
  puzzleId  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, dateKey]) // a day can only be solved once
  @@index([dateKey])
}

model ChatMessage {
  id        String   @id @default(cuid())
  scope     String   @default("global") // "global" (club chat) | "game:<gameId>" (in-game)
  userId    String
  text      String
  createdAt DateTime @default(now())

  // Moderation: soft-delete (retain evidence) + child-reporting.
  hiddenAt    DateTime? // set when hidden by author or coach; row is kept for audit
  deletedById String? // who hid it
  reportCount Int       @default(0)
  reportedAt  DateTime? // most recent report time

  user User @relation(fields: [userId], references: [id])

  @@index([scope, createdAt])
  @@index([reportedAt])
}

model Game {
  id        String   @id @default(cuid())
  whiteId   String
  blackId   String
  fen       String   @default("rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1")
  movesJson String   @default("[]") // JSON array of SAN strings
  turn      String   @default("w") // "w" | "b"
  status    String   @default("active") // "active" | "completed" | "aborted"
  result    String? // "white_wins" | "black_wins" | "draw"
  reason    String? // "checkmate" | "resignation" | "timeout" | "stalemate" | "draw-agreement" | ...
  winnerId  String?
  rated     Boolean  @default(true) // false = Casual: no Elo / record change, XP only

  timeControlSec Int  @default(300) // initial clock per side, 0 = untimed
  incrementSec   Int  @default(0)
  whiteMs        Int? // remaining ms for white
  blackMs        Int? // remaining ms for black
  lastMoveAt     DateTime @default(now())

  drawOfferBy    String? // userId who has a pending draw offer
  rematchOfferBy String? // userId who offered a rematch after the game ended
  rematchGameId  String? // id of the new game once a rematch is accepted

  whiteRatingBefore Int?
  blackRatingBefore Int?
  whiteRatingAfter  Int?
  blackRatingAfter  Int?

  tournamentId String? // set when this game is part of a tournament

  createdAt DateTime  @default(now())
  endedAt   DateTime?

  white User @relation("WhiteGames", fields: [whiteId], references: [id])
  black User @relation("BlackGames", fields: [blackId], references: [id])

  @@index([status])
  @@index([status, lastMoveAt])
  @@index([whiteId])
  @@index([blackId])
  @@index([tournamentId])
}

model Challenge {
  id             String   @id @default(cuid())
  fromId         String
  toId           String? // null = open seek (quick-play matchmaking)
  timeControlSec Int      @default(300)
  incrementSec   Int      @default(0)
  rated          Boolean  @default(true) // carried onto the Game when matched
  status         String   @default("open") // "open" | "accepted" | "declined" | "cancelled"
  gameId         String? // set when accepted
  createdAt      DateTime @default(now())

  from User  @relation("ChallengeFrom", fields: [fromId], references: [id])
  to   User? @relation("ChallengeTo", fields: [toId], references: [id])

  @@index([status])
  @@index([toId])
  @@index([status, timeControlSec, incrementSec])
}
